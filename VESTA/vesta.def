Bootstrap:  docker
From: ubuntu:24.04

%environment
  export LC_ALL=C.utf8  

%post
  export LC_ALL=C.utf8  
  export DEBIAN_FRONTEND=noninteractive

  apt-get update && apt-get -y dist-upgrade && apt-get install -y gawk wget curl \
        libxmu6 libxss1 libxft2 libquadmath0 libpng16-16 bzip2 libwebkit2gtk-4.1-0 \
        libglu1-mesa libglib2.0-0 libgtk-3-0 libgtk-3-dev  libgomp1 && apt-get clean
  
  export TMPD=/tmp/downloads &&   mkdir -p $TMPD
  wget -P $TMPD -c https://jp-minerals.org/vesta/archives/testing/VESTA-gtk3-x86_64.tar.bz2
  cd $TMPD && ls -l  && \
  tar -C /usr/local -xvf VESTA-gtk3-x86_64.tar.bz2 && \

  ln -sf /usr/lib/x86_64-linux-gnu/libwebkit2gtk-4.1.so.0 /usr/lib/x86_64-linux-gnu/libwebkit2gtk-4.0.so.37
  ln -sf /usr/lib/x86_64-linux-gnu/libjavascriptcoregtk-4.1.so.0 /usr/lib/x86_64-linux-gnu/libjavascriptcoregtk-4.0.so.18

%runscript
  /usr/local/VESTA-gtk3-x86_64/VESTA $@
